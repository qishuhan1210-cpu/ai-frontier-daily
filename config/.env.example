# AI 前沿早报 - 敏感环境变量配置模板
# 复制本文件为 .env，并填入真实值
# .env 已列入 .gitignore，不会提交到 Git

# LLM API 配置
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# 飞书机器人 Webhook
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token_here

# 注意：飞书知识库配置（space_id、parent_node_token）由大模型根据对话上下文自行判断，
# 不在此处硬编码。详见 post-runbook.md 发布流程说明。
